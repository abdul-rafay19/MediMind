# ═══════════════════════════════════════════════════════════════
# MediMind .env — NVIDIA NIM Edition
# Replace nvapi-YOUR-KEY-HERE with your actual key from build.nvidia.com
# ═══════════════════════════════════════════════════════════════

SECRET_KEY=medimind-change-this-secret-key-abc123xyz
DATABASE_URL=sqlite+aiosqlite:///./medimind.db
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5500","http://127.0.0.1:3000"]
APP_SITE_URL=http://localhost:3000
APP_SITE_NAME=MediMind

# ── NVIDIA NIM ────────────────────────────────────────────────
OPENROUTER_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=nvapi-YOUR-KEY-HERE



LLM_PRIMARY_MODEL=meta/llama-3.1-8b-instruct
LLM_SECONDARY_MODEL=mistralai/mistral-7b-instruct-v0.3
LLM_FALLBACK_MODEL=microsoft/phi-3-mini-4k-instruct

LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.1

# ── RAG (unchanged) ───────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
KNOWLEDGE_BASE_DIR=./data/knowledge_base
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=5
