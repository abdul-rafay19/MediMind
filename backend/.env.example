# ═══════════════════════════════════════════════════════════
# MediMind — Environment Configuration (Ollama Edition)
# Copy this file to .env and adjust as needed.
# ═══════════════════════════════════════════════════════════

# ── Security ──────────────────────────────────────────────────
# IMPORTANT: Change this to a random secret string in production
SECRET_KEY=medimind-change-this-secret-key-abc123xyz

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./medimind.db

# ── App Settings ─────────────────────────────────────────────
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5500","http://127.0.0.1:3000"]
APP_SITE_URL=http://localhost:3000
APP_SITE_NAME=MediMind

# ── Ollama LLM Settings ───────────────────────────────────────
# Ollama runs locally at http://localhost:11434
# Install: https://ollama.com/download
# Then run: ollama pull mistral
OPENROUTER_BASE_URL=http://localhost:11434/v1
OPENROUTER_API_KEY=ollama

LLM_PRIMARY_MODEL=mistral
LLM_SECONDARY_MODEL=llama3.2
LLM_FALLBACK_MODEL=phi3

LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# ── RAG Settings ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
KNOWLEDGE_BASE_DIR=./data/knowledge_base
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=5
