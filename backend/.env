# ═══════════════════════════════════════════════════════════
# MediMind — .env Configuration
# ⚠️  PASTE YOUR NVIDIA KEY ON LINE BELOW (replace nvapi-PASTE-YOUR-KEY-HERE)
# ═══════════════════════════════════════════════════════════

SECRET_KEY=medimind-secret-key-change-in-production-xyz123
DATABASE_URL=sqlite+aiosqlite:///./medimind.db
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5500","http://127.0.0.1:3000"]
APP_SITE_URL=http://localhost:3000
APP_SITE_NAME=MediMind

# ── NVIDIA NIM API (free) ──────────────────────────────────
# Step 1: Go to https://build.nvidia.com
# Step 2: Click any model (e.g. Llama 3.1)
# Step 3: Click "Get API Key" top-right
# Step 4: Copy your key (starts with nvapi-)
# Step 5: Paste it below replacing nvapi-PASTE-YOUR-KEY-HERE
OPENROUTER_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=nvapi-YOUR-KEY-HERE



# ── Models (these exact names work on NVIDIA NIM) ──────────
LLM_PRIMARY_MODEL=meta/llama-3.1-8b-instruct
LLM_SECONDARY_MODEL=mistralai/mistral-7b-instruct-v0.3
LLM_FALLBACK_MODEL=microsoft/phi-3-mini-4k-instruct

LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.1

# ── RAG ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
KNOWLEDGE_BASE_DIR=./data/knowledge_base
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=5
